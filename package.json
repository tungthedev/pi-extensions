{
  "name": "@tungthedev/pi-extensions",
  "version": "2.0.0-alpha.6",
  "description": "A Pi package containing editor, mermaid, pi-custom, web, skill, codex-content, subagents, droid-content, system-md, shell, settings, and ext-manager extensions.",
  "keywords": [
    "codex",
    "droid",
    "mermaid",
    "pi",
    "pi-extension",
    "pi-package"
  ],
  "homepage": "https://github.com/tungthedev/pi-extensions#readme",
  "bugs": {
    "url": "https://github.com/tungthedev/pi-extensions/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tungthedev/pi-extensions.git"
  },
  "files": [
    "extensions",
    "themes",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run test && bun run lint && bun run typecheck",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint extensions",
    "lint:fix": "oxlint --fix extensions",
    "test": "bun test ./extensions/editor ./extensions/fff ./extensions/pi-custom ./extensions/web ./extensions/skill ./extensions/codex-content ./extensions/droid-content ./extensions/subagents ./extensions/ext-manager ./extensions/system-md ./extensions/todos ./extensions/shell ./extensions/ask-user ./extensions/settings ./extensions/mermaid ./extensions/shared ./extensions/web-search ./extensions/cloudflare-crawl",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.5.2",
    "@google/genai": "^1.43.0",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "beautiful-mermaid": "^1.1.3",
    "better-result": "^2.7.0",
    "file-type": "^21.1.1"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.65.2",
    "@mariozechner/pi-tui": "0.65.2",
    "@sinclair/typebox": "0.34.48",
    "@types/node": "^24.3.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "engines": {
    "bun": ">=1.3.8",
    "node": ">=20.6.0"
  },
  "packageManager": "bun@1.3.8",
  "pi": {
    "extensions": [
      "./extensions/editor/index.ts",
      "./extensions/fff/index.ts",
      "./extensions/mermaid/index.ts",
      "./extensions/pi-custom/index.ts",
      "./extensions/web/index.ts",
      "./extensions/skill/index.ts",
      "./extensions/codex-content/index.ts",
      "./extensions/droid-content/index.ts",
      "./extensions/subagents/index.ts",
      "./extensions/system-md/index.ts",
      "./extensions/shell/index.ts",
      "./extensions/ext-manager/index.ts",
      "./extensions/settings/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
