{
  "name": "@tungthedev/pi-extensions",
  "version": "2.6.1",
  "description": "A Pi package containing editor, mermaid, workspace, web, skill, boomerang, goal, pi-modes, and ext-manager extensions.",
  "keywords": [
    "codex",
    "droid",
    "mermaid",
    "pi",
    "pi-extension",
    "pi-package"
  ],
  "homepage": "https://github.com/tungthedev/pi-extensions#readme",
  "bugs": {
    "url": "https://github.com/tungthedev/pi-extensions/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tungthedev/pi-extensions.git"
  },
  "files": [
    "dist",
    "themes",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./boomerang": {
      "types": "./dist/src/boomerang/index.d.ts",
      "import": "./dist/src/boomerang/index.js"
    },
    "./goal": {
      "types": "./dist/src/goal/index.d.ts",
      "import": "./dist/src/goal/index.js"
    },
    "./pi-modes": {
      "types": "./dist/src/pi-modes/index.d.ts",
      "import": "./dist/src/pi-modes/index.js"
    },
    "./settings": {
      "types": "./dist/src/settings/index.d.ts",
      "import": "./dist/src/settings/index.js"
    },
    "./codex-content": {
      "types": "./dist/src/codex-content/index.d.ts",
      "import": "./dist/src/codex-content/index.js"
    },
    "./droid-content": {
      "types": "./dist/src/droid-content/index.d.ts",
      "import": "./dist/src/droid-content/index.js"
    },
    "./shell": {
      "types": "./dist/src/shell/index.d.ts",
      "import": "./dist/src/shell/index.js"
    },
    "./subagents": {
      "types": "./dist/src/subagents/index.d.ts",
      "import": "./dist/src/subagents/index.js"
    },
    "./system-md": {
      "types": "./dist/src/system-md/index.d.ts",
      "import": "./dist/src/system-md/index.js"
    },
    "./metadata": {
      "types": "./dist/src/metadata.d.ts",
      "import": "./dist/src/metadata.js"
    },
    "./boomerang/metadata": {
      "types": "./dist/src/boomerang/metadata.d.ts",
      "import": "./dist/src/boomerang/metadata.js"
    },
    "./goal/metadata": {
      "types": "./dist/src/goal/metadata.d.ts",
      "import": "./dist/src/goal/metadata.js"
    },
    "./codex-content/metadata": {
      "types": "./dist/src/codex-content/metadata.d.ts",
      "import": "./dist/src/codex-content/metadata.js"
    },
    "./droid-content/metadata": {
      "types": "./dist/src/droid-content/metadata.d.ts",
      "import": "./dist/src/droid-content/metadata.js"
    },
    "./shell/metadata": {
      "types": "./dist/src/shell/metadata.d.ts",
      "import": "./dist/src/shell/metadata.js"
    },
    "./subagents/metadata": {
      "types": "./dist/src/subagents/metadata.d.ts",
      "import": "./dist/src/subagents/metadata.js"
    },
    "./boomerang/primitives": {
      "types": "./dist/src/boomerang/primitives.d.ts",
      "import": "./dist/src/boomerang/primitives.js"
    },
    "./codex-content/primitives": {
      "types": "./dist/src/codex-content/primitives.d.ts",
      "import": "./dist/src/codex-content/primitives.js"
    },
    "./droid-content/primitives": {
      "types": "./dist/src/droid-content/primitives.d.ts",
      "import": "./dist/src/droid-content/primitives.js"
    },
    "./shell/primitives": {
      "types": "./dist/src/shell/primitives.d.ts",
      "import": "./dist/src/shell/primitives.js"
    },
    "./subagents/primitives": {
      "types": "./dist/src/subagents/primitives.d.ts",
      "import": "./dist/src/subagents/primitives.js"
    },
    "./*": {
      "types": "./dist/src/*.d.ts",
      "import": "./dist/src/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/src/subagents && cp src/subagents/interactive-launcher.mjs dist/src/subagents/interactive-launcher.mjs && cp -R src/subagents/assets dist/src/subagents/assets",
    "check": "bun run test && bun run lint && bun run typecheck && bun run build && bun run check:imports",
    "check:imports": "node scripts/check-import-contracts.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint extensions src",
    "lint:fix": "oxlint --fix extensions src",
    "test": "bun test ./src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.5.2",
    "@google/genai": "^1.43.0",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "beautiful-mermaid": "^1.1.3",
    "better-result": "^2.7.0",
    "file-type": "^21.1.1",
    "openai": "6.26.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@earendil-works/pi-tui": "0.74.0",
    "@types/node": "^24.3.0",
    "@types/turndown": "^5.0.6",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typebox": "^1.1.24",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "bun": ">=1.3.8",
    "node": ">=20.6.0"
  },
  "packageManager": "bun@1.3.8",
  "pi": {
    "extensions": [
      "./dist/extensions/editor.js",
      "./dist/extensions/mermaid.js",
      "./dist/extensions/web.js",
      "./dist/extensions/skill.js",
      "./dist/extensions/boomerang.js",
      "./dist/extensions/goal.js",
      "./dist/extensions/workspace.js",
      "./dist/extensions/pi-modes.js",
      "./dist/extensions/ext-manager.js",
      "./dist/extensions/openai-responses-image-patch.js"
    ],
    "themes": [
      "./themes"
    ]
  }
}
