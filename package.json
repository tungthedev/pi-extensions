{
  "name": "@tungthedev/pi-extensions",
  "version": "2.5.0",
  "description": "A Pi package containing editor, mermaid, workspace, web, skill, boomerang, pi-modes, and ext-manager extensions.",
  "keywords": [
    "codex",
    "droid",
    "mermaid",
    "pi",
    "pi-extension",
    "pi-package"
  ],
  "homepage": "https://github.com/tungthedev/pi-extensions#readme",
  "bugs": {
    "url": "https://github.com/tungthedev/pi-extensions/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tungthedev/pi-extensions.git"
  },
  "files": [
    "extensions",
    "src",
    "themes",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run test && bun run lint && bun run typecheck",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint extensions src",
    "lint:fix": "oxlint --fix extensions src",
    "test": "bun test ./src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.5.2",
    "@google/genai": "^1.43.0",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "beautiful-mermaid": "^1.1.3",
    "better-result": "^2.7.0",
    "file-type": "^21.1.1",
    "openai": "6.26.0"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "0.72.1",
    "@mariozechner/pi-ai": "0.72.1",
    "@mariozechner/pi-coding-agent": "0.72.1",
    "@mariozechner/pi-tui": "0.72.1",
    "@types/node": "^24.3.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typebox": "^1.1.24",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "bun": ">=1.3.8",
    "node": ">=20.6.0"
  },
  "packageManager": "bun@1.3.8",
  "pi": {
    "extensions": [
      "./extensions/editor.ts",
      "./extensions/mermaid.ts",
      "./extensions/web.ts",
      "./extensions/skill.ts",
      "./extensions/boomerang.ts",
      "./extensions/workspace.ts",
      "./extensions/pi-modes.ts",
      "./extensions/ext-manager.ts",
      "./extensions/openai-responses-image-patch.ts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
